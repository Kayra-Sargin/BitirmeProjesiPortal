@model BitirmeProjesiPortal.Models.ClassReference

<form method="post" asp-action="Edit">
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">Edit Class</h2>
        </div>
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        @if (ViewBag.Message != null)
        {
            <div class="form-group" style="color:green">@ViewBag.Message</div>
        }
        <input type="hidden" asp-for="UserId" />

        <div class="form-group">
            <label asp-for="CRN" class="control-label"></label>
            <input asp-for="CRN" class="form-control" />
            <span asp-validation-for="CRN" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label for="ClassId">Ders Kodu</label>

            <select asp-for="ClassId" class="form-select"
                    asp-items="@(new SelectList(ViewBag.ClassList, "Id", "ClassName"))">
                <option value="">Seçiniz</option>
            </select>

            <span asp-validation-for="ClassId" class="text-danger"></span>
        </div>

        <br />
        <div class="form-group">
            <input type="submit" value="Update" class="btn btn-primary" />
        </div>
        <a asp-controller="ClassReference" asp-action="Index" class="btn btn-secondary">
            Back to the List
        </a>
    </div>
</form>
