@model BitirmeProjesiPortal.Models.Assignment

<form method="post" asp-action="Edit" enctype="multipart/form-data">
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">Edit Assignment</h2>
        </div>
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        @if (ViewBag.Message != null)
        {
            <div class="form-group" style="color:green">@ViewBag.Message</div>
        }

        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ClassReferenceId" />
        <input type="hidden" asp-for="AnswerFilePath" />

        <div class="form-group mb-3">
            <label asp-for="Header" class="control-label"></label>
            <input asp-for="Header" class="form-control" />
            <span asp-validation-for="Header" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Content" class="control-label"></label>
            <input asp-for="Content" class="form-control" />
            <span asp-validation-for="Content" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="AnswerFile" class="control-label">Upload New Answer File (Optional)</label>
            <input type="file" asp-for="AnswerFile" class="form-control" />
            <span asp-validation-for="AnswerFile" class="text-danger"></span>

            @if (!string.IsNullOrEmpty(Model.AnswerFilePath))
            {
                <div class="mt-2">
                    <small class="text-muted">
                        Current file: <a href="@Model.AnswerFilePath" target="_blank">Download/View</a>. <br />
                        <em>Note: Uploading a new file will replace the existing one.</em>
                    </small>
                </div>
            }
        </div>

        <button type="submit" class="btn btn-primary">Update</button>
        <div class="mt-2">
            <a asp-action="Index" asp-route-classReferenceId="@Model.ClassReferenceId">Back to List</a>
        </div>
    </div>
</form>